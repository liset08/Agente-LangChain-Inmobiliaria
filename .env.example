# ============================================================
# Variables de entorno — Agente IA Alpha State (plantilla)
# Copia este archivo como .env y completa los valores reales.
#   cp .env.example .env
# NUNCA versionar el .env con credenciales reales.
# ============================================================

# ============================================
# LLM + EMBEDDINGS (OpenAI) — OBLIGATORIA
# gpt-4.1 (chat) y text-embedding-ada-002 (RAG)
# ============================================
OPENAI_API_KEY=sk-...

# Otras API keys de modelos (no usada por el código actual del agente)
GEMINI_API_KEY=

# ============================================
# HISTORIAL DE CONVERSACIÓN (PostgreSQL / Supabase) — OBLIGATORIAS
# ============================================
DB_USER=postgres.xxxxxxxxxxxx
DB_PASSWORD=
DB_HOST=aws-x-xx-xxxx-x.pooler.supabase.com
DB_PORT=5432                      # opcional (default 5432)
DB_NAME=postgres                  # opcional (default postgres)
DB_TABLE_NAME=chat_history        # opcional (default chat_history)

# ============================================
# BASE DE CONOCIMIENTO RAG (Qdrant) — OBLIGATORIAS
# QDRANT_API_KEY = mismo valor que QDRANT__SERVICE__API_KEY del servidor (Easypanel)
# QDRANT_URL = dominio público https (sin :6333 si va detrás del proxy)
# ============================================
QDRANT_URL=https://tu-qdrant.easypanel.host
QDRANT_API_KEY=
QDRANT_COLLECTION=alpha-state-conocimiento   # opcional (default alpha-state-conocimiento)

# --- LEGACY: Pinecone (reemplazado por Qdrant; conservar solo si vuelves atrás) ---
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=

# ============================================
# BÚSQUEDA EN INTERNET (Tavily) — OBLIGATORIA
# API key gratis en https://tavily.com
# ============================================
TAVILY_API_KEY=tvly-...

# ============================================
# DEPARTAMENTOS EN ALQUILER (Google Sheets) — OBLIGATORIA la primera
# El sheet debe estar compartido (Lector) con el client_email del service account
# ============================================
GOOGLE_SHEETS_SPREADSHEET_ID=                # ID entre /d/ y /edit de la URL del sheet
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google-service-account.json   # opcional (default)
GOOGLE_SHEETS_WORKSHEET=                     # opcional (vacío = primera pestaña)

# ============================================
# CANAL CHATWOOT — solo si usas main_chatwoot.py
# ============================================
CHATWOOT_BASE_URL=https://tu-chatwoot.ejemplo.com
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_BOT_LABEL=atiende-ia                # opcional (default atiende-ia)

# ============================================
# AGENTE — opcionales
# ============================================
AGENT_TIMEZONE=America/Lima                  # opcional (default America/Lima)
AGENT_VERSION=1                              # opcional: 1 = agent.py (loop manual), 2 = agent_v2.py (create_agent)
